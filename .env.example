# PIWA Configuration

# The absolute path to the directory where PIWA will store its workspace data
WORK_DIR=./work

# AGENT_NUMBER: The WhatsApp number the AI agent uses to chat with you.
# Format: Country code + number, NO plus sign (e.g., 1234567890)
AGENT_NUMBER=

# OWNER_NUMBER: Your personal WhatsApp number. This is the only number allowed to command the agent.
# Format: Country code + number, NO plus sign (e.g., 0987654321)
OWNER_NUMBER=

# ANTHROPIC_API_KEY: API key for the pi coding agent's LLM provider.
# Used by @mariozechner/pi-coding-agent.
ANTHROPIC_API_KEY=
